{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "collectorUrl": { "type": "string" },
    "keyId": { "type": "string" },
    "sharedSecret": { "type": "string" },
    "flushIntervalMs": { "type": "integer", "minimum": 5000, "maximum": 600000 },
    "batchSize": { "type": "integer", "minimum": 1, "maximum": 500 },
    "debug": { "type": "boolean" },
    "collectTitles": { "type": "boolean" }
  },
  "required": ["collectorUrl", "keyId", "sharedSecret"]
}
